# AuditLayer worker environment (copy to worker/.env or set in systemd)

# --- Supabase (service role bypasses RLS) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
AUDITLAYER_REPORTS_BUCKET=reports
# Legacy compatibility only. The worker stores private paths; authorized web
# routes create short-lived URLs on demand.
AUDITLAYER_SIGNED_URL_TTL=900

# --- Hermes connectivity ---
# HERMES_MODE:
#   http       — talk to an already-running gateway api_server (default; Hetzner systemd)
#   subprocess — spawn `hermes gateway run` on first job, stop after idle timeout
#   inprocess  — call run_agent.AIAgent directly (production; needs local hermes-agent)
HERMES_MODE=inprocess
# On the Hetzner VM the gateway api_server listens at 127.0.0.1:8642.
HERMES_API_BASE=http://127.0.0.1:8642/v1
# Subprocess mode only (ignored when HERMES_MODE=http):
# HERMES_GATEWAY_BIN=/Users/you/.local/bin/hermes
# HERMES_SUBPROCESS_IDLE_SECONDS=120
# HERMES_GATEWAY_STARTUP_TIMEOUT=60
# Inprocess mode only:
# HERMES_AGENT_ROOT=/Users/you/.hermes/hermes-agent
# HERMES_API_KEY MUST equal the Hermes Gateway API_SERVER_KEY.
HERMES_API_KEY=CHANGE-ME
HERMES_MODEL=deepseek-v4-flash
HERMES_PROVIDER=deepseek
HERMES_TIMEOUT_SECONDS=600
AUDITLAYER_TOOLSETS=web,browser,x_search
HERMES_MAX_TOKENS=32000
HERMES_TEMPERATURE=0.2
# Canonical versioned report role copied beside the production worker.
# Defaults to <repo-root>/hermes-profile; explicit here for production clarity.
ALM_PROFILE_BUNDLE_ROOT=/opt/auditlayer/hermes-profile

# --- Sentry observability ---------------------------------------------------
# Optional. Worker remains functional when absent. Events are scrubbed before send.
# SENTRY_DSN=https://PUBLIC_KEY@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.02
# SENTRY_RELEASE=<git-sha>

# --- Public web research ---
# Recommended production backend: Exa. AuditLayer performs a small bounded
# search-and-extract sweep; it does not need a self-hosted crawler stack.
# Without one supported backend, reports continue using connected/platform data
# but explicitly disclose that no web evidence was verified.
EXA_API_KEY=YOUR-EXA-API-KEY
# Alternatives supported by Hermes: TAVILY_API_KEY, FIRECRAWL_API_KEY,
# FIRECRAWL_API_URL (self-hosted), BRAVE_SEARCH_API_KEY, or SEARXNG_URL.

# --- Generation backend: hermes (prod) | mock (QA/CI) ---
AUDITLAYER_GENERATOR=hermes

# --- Safety caps (also read live from app_settings) ---
AUDITLAYER_TOKEN_CAP=120000
AUDITLAYER_COST_CAP_USD=3.0
# Model pricing for cost estimation (USD per 1M tokens). Defaults are
# deepseek-v4-pro-class rough numbers; set to your contracted rates.
AUDITLAYER_PRICE_IN_PER_MTOK=0.27
AUDITLAYER_PRICE_OUT_PER_MTOK=1.10

# --- Queue loop ---
AUDITLAYER_POLL_INTERVAL=5
# Loopback-only health endpoint for systemd/monitoring probes.
AUDITLAYER_HEALTH_HOST=127.0.0.1
# Optional for singleton runs. Template instances derive 8788, 8789, ...
# AUDITLAYER_HEALTH_PORT=8787
# Seconds between synthetic phase events during long generations (0 = immediate).
AUDITLAYER_PHASE_INTERVAL=20

# --- Standalone demo output ---
AUDITLAYER_OUTPUT_DIR=var/worker-out
