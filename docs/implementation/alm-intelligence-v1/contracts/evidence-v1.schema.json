{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "alm/evidence-v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "subject_id",
    "channel_id",
    "source_type",
    "observed_at",
    "content_hash",
    "confidence",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "evidence_id": {
      "type": "string",
      "minLength": 3
    },
    "subject_id": {
      "type": "string",
      "format": "uuid"
    },
    "channel_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "source_type": {
      "enum": [
        "connected_api",
        "official_web",
        "public_web",
        "user_context",
        "methodology"
      ]
    },
    "source_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "content_hash": {
      "type": "string",
      "minLength": 16
    },
    "confidence": {
      "enum": [
        "low",
        "medium",
        "high",
        "authoritative"
      ]
    },
    "coverage": {
      "type": "object"
    },
    "payload": {
      "type": "object"
    }
  }
}
