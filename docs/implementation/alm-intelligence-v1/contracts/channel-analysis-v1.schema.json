{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "alm/channel-analysis-v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "channel_type",
    "evidence_coverage",
    "findings",
    "recommendations",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "channel_type": {
      "enum": [
        "instagram",
        "website",
        "youtube",
        "tiktok",
        "x",
        "linkedin"
      ]
    },
    "evidence_coverage": {
      "type": "object",
      "required": [
        "used",
        "unavailable"
      ],
      "properties": {
        "used": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unavailable": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "object",
        "required": [
          "id",
          "claim",
          "evidence_ids",
          "confidence",
          "dimension_impacts"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "claim": {
            "type": "string"
          },
          "evidence_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "confidence": {
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "dimension_impacts": {
            "type": "object",
            "additionalProperties": {
              "type": "number",
              "minimum": -100,
              "maximum": 100
            }
          }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object"
      }
    },
    "context_update_proposals": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
