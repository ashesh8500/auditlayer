{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "alm/intelligence-result-v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "subject_id",
    "brief_version",
    "evidence_snapshot_id",
    "channel_results",
    "scores",
    "findings",
    "recommendations",
    "change_explanations"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "subject_id": {
      "type": "string",
      "format": "uuid"
    },
    "brief_version": {
      "type": "integer",
      "minimum": 1
    },
    "evidence_snapshot_id": {
      "type": "string",
      "format": "uuid"
    },
    "channel_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "channel-analysis-v1.schema.json"
      }
    },
    "scores": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "dimension",
          "value",
          "evidence_ids",
          "methodology_version"
        ],
        "properties": {
          "dimension": {
            "type": "string"
          },
          "value": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 100
          },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "methodology_version": {
            "type": "string"
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "change_explanations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
