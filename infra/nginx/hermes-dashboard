# Canonical loopback origin for the Cloudflare tunnel serving hermes.kalanak.com.
# The dashboard remains unchanged. Only the explicitly prefixed operator API is
# forwarded to the API-key-protected Hermes listener.
server {
    listen 127.0.0.1:9120;
    server_name _;

    client_max_body_size 50m;

    location = /operator-api/p/alm/v1/chat/completions {
        limit_except POST { deny all; }
        client_max_body_size 1m;

        proxy_pass http://127.0.0.1:8642/p/alm/v1/chat/completions;
        proxy_http_version 1.1;
        proxy_set_header Host 127.0.0.1:8642;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header X-Hermes-Session-Id $http_x_hermes_session_id;
        proxy_set_header X-Hermes-Session-Key $http_x_hermes_session_key;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 5s;
        proxy_send_timeout 65s;
        proxy_read_timeout 65s;
        proxy_buffering off;
        add_header Cache-Control "no-store" always;
        add_header X-Content-Type-Options "nosniff" always;
    }

    location /operator-api/ {
        return 404;
    }

    location / {
        proxy_pass http://100.83.195.75:9119;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host 100.83.195.75:9119;
        proxy_set_header Origin "";
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400s;
        proxy_buffering off;
    }
}
