#!/usr/bin/env bash
# AuditLayer pre-commit hook ŌĆö runs on every `git commit`.
# Checks enforce code quality and prevent common mistakes.
# Install: `make install-hooks` or `git config core.hooksPath .githooks`
set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

fail() {
  echo -e "${RED}[FAIL]${NC} $*" >&2
  exit 1
}

warn() {
  echo -e "${YELLOW}[WARN]${NC} $*" >&2
}

# --- Gather staged changes ---------------------------------------------------
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [[ -z "$STAGED_FILES" ]]; then
  exit 0
fi

# --- 1. Merge conflict markers -----------------------------------------------
if echo "$STAGED_FILES" | xargs grep -Il '^<<<<<<< \|^=======\|^>>>>>>> ' 2>/dev/null; then
  fail "Merge conflict markers found in staged files (listed above). Resolve before committing."
fi

# --- 2. Large files (warn at 500KB, fail at 1MB) -----------------------------
while IFS= read -r file; do
  size=$(git show :"$file" 2>/dev/null | wc -c || stat -c%s "$file" 2>/dev/null || echo 0)
  if [[ "$size" -gt 1048576 ]]; then
    fail "File '$file' is $(numfmt --to=iec "$size") ŌĆö > 1MB. Use Git LFS or remove from commit."
  elif [[ "$size" -gt 512000 ]]; then
    warn "File '$file' is $(numfmt --to=iec "$size") ŌĆö > 500KB. Consider Git LFS."
  fi
done <<< "$STAGED_FILES"

# --- 3. Debug statements (Python print / JS console.log / debugger) ---------
PY_DEBUG=$(echo "$STAGED_FILES" | grep '\.py$' | xargs grep -ln '^\s*print(' 2>/dev/null || true)
JS_DEBUG=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx|js|jsx)$' | xargs grep -ln 'console\.log\|debugger' 2>/dev/null || true)

for f in $PY_DEBUG; do
  warn "Python file '$f' contains print() ŌĆö is this intentional?"
done
for f in $JS_DEBUG; do
  warn "JS/TS file '$f' contains console.log/debugger ŌĆö is this intentional?"
done

# --- 4. Template guard (existing) --------------------------------------------
if echo "$STAGED_FILES" | grep -q '^worker/auditlayer_worker/templates/master-skeleton\.html$'; then
  warn "master-skeleton.html modified ŌĆö verify CSS + 15 section markers."
fi

# --- 5. .env files should never be committed ---------------------------------
ENV_STAGED=$(echo "$STAGED_FILES" | grep -E '(^|/)\.env$' | grep -v '\.env\.example$' | grep -v '\.env\.local' || true)
if [[ -n "$ENV_STAGED" ]]; then
  fail "Actual .env files should never be committed: $ENV_STAGED"
fi

# --- 6. Python syntax check (staged .py files) -------------------------------
PY_FILES=$(echo "$STAGED_FILES" | grep '\.py$' || true)
if [[ -n "$PY_FILES" ]]; then
  echo "$PY_FILES" | tr '\n' '\0' | xargs -0 -P"$(nproc)" python3 -m py_compile 2>&1 || fail "Python syntax error in staged files."
fi
