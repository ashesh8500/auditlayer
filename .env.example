# AuditLayer runtime
AUDITLAYER_ENV=development
AUDITLAYER_DB_PATH=var/data/auditlayer.db
AUDITLAYER_REPORT_DIR=var/reports
AUDITLAYER_ADMIN_TOKEN=change-me-before-production
AUDITLAYER_MAX_REQUEST_BYTES=1048576

# Generation mode: mock or hermes
AUDITLAYER_GENERATOR=mock
HERMES_API_BASE=http://127.0.0.1:8642/v1
# Must match the Hermes Gateway API_SERVER_KEY.
HERMES_API_KEY=
HERMES_MODEL=deepseek-v4-pro
HERMES_TIMEOUT_SECONDS=300

# Stripe webhook verification
STRIPE_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_SUCCESS_URL=http://127.0.0.1:8000/dashboard?checkout=success
STRIPE_CANCEL_URL=http://127.0.0.1:8000/dashboard?checkout=cancelled

# Email delivery: outbox or smtp
AUDITLAYER_EMAIL_MODE=outbox
AUDITLAYER_EMAIL_FROM=AuditLayer <noreply@auditlayer.local>
AUDITLAYER_EMAIL_OUTBOX=var/email-outbox.jsonl
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# PDF export: stub or browser
AUDITLAYER_PDF_MODE=stub
AUDITLAYER_PDF_DIR=var/pdfs
CHROMIUM_PATH=
