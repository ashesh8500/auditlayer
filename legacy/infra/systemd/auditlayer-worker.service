[Unit]
Description=AuditLayer audit worker
After=network-online.target auditlayer-web.service
Wants=network-online.target

[Service]
Type=simple
User=asheshkaji
WorkingDirectory=/home/asheshkaji/projects/auditlayer
EnvironmentFile=/etc/auditlayer/auditlayer.env
ExecStart=/home/asheshkaji/projects/auditlayer/.venv/bin/python -m auditlayer worker --interval 15
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target

