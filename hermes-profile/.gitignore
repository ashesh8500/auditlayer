# Never commit local credentials or runtime state
.env
auth.json
auth.lock
state.db*
sessions/
logs/
cache/
models_dev_cache.json
*.lock
response_store.db*
processes.json
.update_check
bin/
.skills_prompt_snapshot.json

# Export only canonical distribution files and requested skills
*
!.gitignore
!config.yaml
!SOUL.md
!README.md
!manifest.yaml
!shared/
!shared/**
!profiles/
!profiles/**
!scripts/
!scripts/**
!tests/
!tests/**
!skills/
!skills/productivity/
!skills/productivity/alm-report-generator/
!skills/productivity/alm-report-generator/**
!skills/productivity/social-media-audit/
!skills/productivity/social-media-audit/**
!skills/auditlayer/
!skills/auditlayer/auditlayer-master-template/
!skills/auditlayer/auditlayer-master-template/**
!skills/ppt-production-expert/
!skills/ppt-production-expert/narin-brand-audits/
!skills/ppt-production-expert/narin-brand-audits/**

# Generated Python artifacts are never part of the profile distribution.
**/__pycache__/
**/*.pyc
